                {/* Gradient Overlay */}
                <motion.div 
                  className="absolute inset-0 bg-gradient-to-br from-blue-600/30 via-purple-600/20 to-amber-500/30 z-10"
                  whileHover={{ opacity: 0.8 }}
                  transition={{ duration: 0.3 }}
                />
                
                <Image
                  src="https://images.unsplash.com/photo-1582555172866-f73bb12a2ab3?q=80&w=800&auto=format&fit=crop"
                  alt="About MN Studio"
                  width={600}
                  height={700}
                  className="w-full h-[500px] object-cover group-hover:scale-110 transition-transform duration-700"
                />

                {/* Floating Border Effect */}
                <motion.div 
                  className="absolute -inset-1 bg-gradient-to-r from-amber-500 via-blue-500 to-purple-500 rounded-3xl opacity-0 group-hover:opacity-50 blur-sm"
                  animate={{ rotate: 360 }}
                  transition={{ duration: 8, repeat: Infinity, ease: "linear" }}
                />
              </motion.div>

              {/* Enhanced Floating Stats Card */}
              <motion.div 
                className="absolute -bottom-8 -right-8 bg-gradient-to-br from-amber-500 via-amber-600 to-orange-600 rounded-3xl p-8 text-white shadow-2xl border border-white/20 backdrop-blur-sm z-20"
                initial={{ opacity: 0, scale: 0.5, y: 50 }}
                whileInView={{ opacity: 1, scale: 1, y: 0 }}
                viewport={{ once: true }}
                transition={{ duration: 0.8, delay: 0.6 }}
                whileHover={{ 
                  scale: 1.1, 
                  y: -10,
                  boxShadow: "0 25px 50px -12px rgba(0, 0, 0, 0.5)"
                }}
              >
                <motion.div className="text-center">
                  <motion.div 
                    className="text-4xl font-bold mb-2"
                    animate={{ scale: [1, 1.1, 1] }}
                    transition={{ duration: 2, repeat: Infinity }}
                  >
                    500+
                  </motion.div>
                  <div className="text-sm opacity-90 font-medium">Happy Clients</div>
                </motion.div>

                {/* Glow Effect */}
                <motion.div 
                  className="absolute -inset-2 bg-gradient-to-r from-amber-400 to-orange-500 rounded-3xl opacity-0 blur-xl"
                  whileHover={{ opacity: 0.6 }}
                  transition={{ duration: 0.3 }}
                />
              </motion.div>

              {/* Decorative Elements */}
              <motion.div 
                className="absolute -top-8 -left-8 w-32 h-32 bg-gradient-to-br from-blue-500/20 to-purple-500/20 rounded-full blur-2xl"
                animate={{
                  scale: [1, 1.3, 1],
                  opacity: [0.3, 0.6, 0.3]
                }}
                transition={{ duration: 4, repeat: Infinity }}
              />
            </motion.div>

            {/* Enhanced Content Side */}
            <motion.div 
              className="space-y-8"
              initial={{ opacity: 0, x: 60 }}
              whileInView={{ opacity: 1, x: 0 }}
              viewport={{ once: true }}
              transition={{ duration: 1, delay: 0.4 }}
            >
              {/* Animated Badge */}
              <motion.div
                initial={{ opacity: 0, y: 20 }}
                whileInView={{ opacity: 1, y: 0 }}
                viewport={{ once: true }}
                transition={{ duration: 0.6, delay: 0.6 }}
              >
                <motion.p 
                  className="text-amber-400 uppercase tracking-wide text-sm font-semibold mb-4 flex items-center gap-2"
                  whileHover={{ x: 10 }}
                  transition={{ type: "spring", stiffness: 300 }}
                >
                  <motion.span
                    animate={{ rotate: [0, 360] }}
                    transition={{ duration: 2, repeat: Infinity, ease: "linear" }}
                    className="w-2 h-2 bg-amber-400 rounded-full"
                  />
                  Our Story
                </motion.p>
              </motion.div>

              {/* Animated Title */}
              <motion.h2 
                className="text-5xl md:text-6xl font-bold mb-6 leading-tight"
                initial={{ opacity: 0, y: 30 }}
                whileInView={{ opacity: 1, y: 0 }}
                viewport={{ once: true }}
                transition={{ duration: 0.8, delay: 0.8 }}
              >
                <span className="text-white">About </span>
                <motion.span 
                  className="bg-gradient-to-r from-amber-400 via-amber-500 to-amber-600 bg-clip-text text-transparent"
                  animate={{
                    backgroundPosition: ["0% 50%", "100% 50%", "0% 50%"],
                  }}
                  transition={{ duration: 3, repeat: Infinity }}
                  style={{ backgroundSize: "200% auto" }}
                >
                  MN Studio
                </motion.span>
              </motion.h2>

              {/* Animated Paragraphs */}
              <motion.div className="space-y-6">
                <motion.p 
                  className="text-white/80 text-lg leading-relaxed"
                  initial={{ opacity: 0, y: 20 }}
                  whileInView={{ opacity: 1, y: 0 }}
                  viewport={{ once: true }}
                  transition={{ duration: 0.6, delay: 1 }}
                >
                  <motion.span 
                    className="text-amber-400 font-semibold"
                    whileHover={{ scale: 1.05 }}
                    transition={{ type: "spring", stiffness: 300 }}
                  >
                    Shridhar Kokitkar
                  </motion.span> founded MN Studio Photography with a vision to provide exceptional photography services. We are passionate about capturing moments and creating visual stories that resonate with emotion and authenticity.
                </motion.p>
                
                <motion.p 
                  className="text-white/70 leading-relaxed"
                  initial={{ opacity: 0, y: 20 }}
                  whileInView={{ opacity: 1, y: 0 }}
                  viewport={{ once: true }}
                  transition={{ duration: 0.6, delay: 1.2 }}
                >
                  With over a decade of experience, we specialize in creating timeless images that exceed expectations and preserve your most precious memories with artistic excellence and professional precision.
                </motion.p>
              </motion.div>

              {/* Enhanced CTA Button */}
              <motion.div
                initial={{ opacity: 0, y: 30 }}
                whileInView={{ opacity: 1, y: 0 }}
                viewport={{ once: true }}
                transition={{ duration: 0.6, delay: 1.4 }}
                className="relative"
              >
                <motion.div
                  whileHover={{ 
                    scale: 1.05, 
                    y: -5,
                    boxShadow: "0 25px 50px -12px rgba(245, 158, 11, 0.4)"
                  }}
                  whileTap={{ scale: 0.98 }}
                  transition={{ type: "spring", stiffness: 300, damping: 20 }}
                  className="relative group"
                >
                  <Link 
                    href="/about" 
                    className="inline-flex items-center px-10 py-4 bg-gradient-to-r from-amber-500 to-amber-600 text-white font-semibold rounded-2xl shadow-xl cursor-pointer relative overflow-hidden"
                  >
                    {/* Animated Background */}
                    <motion.div 
                      className="absolute inset-0 bg-gradient-to-r from-amber-600 to-amber-700"
                      initial={{ x: "-100%" }}
                      whileHover={{ x: "0%" }}
                      transition={{ duration: 0.3 }}
                    />
                    
                    <span className="relative z-10 mr-3">Learn More About Us</span>
                    <motion.svg 
                      className="w-5 h-5 relative z-10" 
                      fill="none" 
                      stroke="currentColor" 
                      viewBox="0 0 24 24"
                      animate={{ x: [0, 5, 0] }}
                      transition={{ duration: 2, repeat: Infinity }}
                    >
                      <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </motion.svg>
                  </Link>

                  {/* Particle Effects on Hover */}
                  <motion.div 
                    className="absolute -inset-2 bg-gradient-to-r from-amber-400 to-orange-500 rounded-2xl opacity-0 blur-xl group-hover:opacity-30 pointer-events-none"
                    transition={{ duration: 0.3 }}
                  />
                </motion.div>
              </motion.div>
            </motion.div>
          </div>
        </div>
      </motion.section>

      {/* Features Section */}
      <motion.section 
        id="features" 
        className="relative overflow-hidden py-32"
        initial={{ opacity: 0 }}
        whileInView={{ opacity: 1 }}
        viewport={{ once: true }}
        transition={{ duration: 1 }}
      >
        {/* Animated Background Grid */}
        <motion.div 
          className="absolute inset-0 opacity-10"
          style={{
            backgroundImage: `radial-gradient(circle at 2px 2px, rgba(255,255,255,0.3) 1px, transparent 0)`,
            backgroundSize: "50px 50px"
          }}
          animate={{
            backgroundPosition: ["0px 0px", "50px 50px", "0px 0px"]
          }}
          transition={{ duration: 20, repeat: Infinity, ease: "linear" }}
        />

        {/* Floating Geometric Shapes */}
        <motion.div 
          className="absolute top-1/4 left-1/4 w-64 h-64 bg-gradient-to-br from-blue-500/10 to-purple-500/10 rounded-full blur-3xl"
          animate={{
            x: [0, 100, 0],
            y: [0, -50, 0],
            scale: [1, 1.2, 1]
          }}
          transition={{ duration: 8, repeat: Infinity, ease: "easeInOut" }}
        />
        <motion.div 
          className="absolute top-3/4 right-1/4 w-48 h-48 bg-gradient-to-br from-amber-500/10 to-orange-500/10 rounded-full blur-3xl"
          animate={{
            x: [0, -80, 0],
            y: [0, 60, 0],
            scale: [1, 0.8, 1]
          }}
          transition={{ duration: 6, repeat: Infinity, ease: "easeInOut" }}
        />

        <div className="max-w-7xl mx-auto px-6 relative z-10">
          
          {/* Enhanced Header Section */}
          <motion.div 
            className="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-20"
            initial="hidden"
            whileInView="visible"
            viewport={{ once: true }}
            variants={{
              hidden: {},
              visible: { transition: { staggerChildren: 0.3 }}
            }}
          >
            <motion.div
              variants={{
                hidden: { opacity: 0, x: -60 },
                visible: { opacity: 1, x: 0 }
              }}
            >
              {/* Animated Badge */}
              <motion.p 
                className="text-amber-400 uppercase tracking-wide text-sm font-semibold mb-6 flex items-center gap-3"
                whileHover={{ x: 10 }}
                transition={{ type: "spring", stiffness: 300 }}
              >
                <motion.div
                  className="w-3 h-3 bg-amber-400 rounded-full"
                  animate={{ scale: [1, 1.3, 1], opacity: [1, 0.7, 1] }}
                  transition={{ duration: 2, repeat: Infinity }}
                />
                Key Advantages
              </motion.p>

              {/* Animated Title */}
              <motion.h2 
                className="text-5xl md:text-6xl font-bold text-white mb-8 leading-tight"
                variants={{
                  hidden: { opacity: 0, y: 30 },
                  visible: { opacity: 1, y: 0 }
                }}
              >
                <span className="text-white">Why Choose </span>
                <motion.span 
                  className="bg-gradient-to-r from-amber-400 via-amber-500 to-amber-600 bg-clip-text text-transparent"
                  animate={{
                    backgroundPosition: ["0% 50%", "100% 50%", "0% 50%"],
                  }}
                  transition={{ duration: 3, repeat: Infinity }}
                  style={{ backgroundSize: "200% auto" }}
                >
                  Us?
                </motion.span>
              </motion.h2>
            </motion.div>

            <motion.div
              variants={{
                hidden: { opacity: 0, x: 60 },
                visible: { opacity: 1, x: 0 }
              }}
            >
              <motion.p 
                className="text-white/80 text-xl leading-relaxed"
                initial={{ opacity: 0, y: 20 }}
                whileInView={{ opacity: 1, y: 0 }}
                viewport={{ once: true }}
                transition={{ duration: 0.8, delay: 0.6 }}
              >
                MN Studio Photography offers <motion.span 
                  className="text-amber-400 font-semibold"
                  whileHover={{ scale: 1.05 }}
                  transition={{ type: "spring", stiffness: 300 }}
                >
                  unparalleled photography services
                </motion.span>, capturing moments with artistry and precision. We deliver exceptional results, tailored experiences, and lasting memories for every client.
              </motion.p>
            </motion.div>
          </motion.div>

          {/* Enhanced Features Grid */}
          <motion.div 
            className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8"
            initial="hidden"
            whileInView="visible"
            viewport={{ once: true }}
            variants={{
              hidden: {},
              visible: { transition: { staggerChildren: 0.15 }}
            }}
          >
            {[
              {
                title: "High-Quality Equipment",
                description: "Professional cameras and lighting for stunning visuals",
                gradient: "from-blue-500 to-purple-600",
                icon: (
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                ),
                iconSecond: (
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
                )
              },
              {
                title: "Creative Expertise",
                description: "Expertise in various photography styles and techniques",
                gradient: "from-amber-500 to-orange-600",
                icon: (
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                )
              },
              {
                title: "Custom Packages", 
                description: "Tailored packages designed for your specific needs",
                gradient: "from-emerald-500 to-teal-600",
                icon: (
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1" />
                )
              },
              {
                title: "Passionate Team",
                description: "Dedicated professionals committed to excellence",
                gradient: "from-pink-500 to-rose-600",
                icon: (
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                )
              }
            ].map((feature, index) => (
              <motion.div 
                key={feature.title}
                className="text-center group cursor-pointer"
                variants={{
                  hidden: { opacity: 0, y: 60, scale: 0.8 },
                  visible: { opacity: 1, y: 0, scale: 1 }
                }}
                whileHover={{ y: -10, scale: 1.05 }}
                transition={{ type: "spring", stiffness: 300, damping: 20 }}
              >
                {/* Enhanced Icon Container */}
                <motion.div 
                  className={`relative w-24 h-24 bg-gradient-to-br ${feature.gradient} rounded-3xl flex items-center justify-center mx-auto mb-8 overflow-hidden`}
                  whileHover={{ 
                    rotate: [0, -10, 10, 0],
                    scale: 1.1 
                  }}
                  transition={{ duration: 0.6 }}
                >
                  {/* Background Glow Effect */}
                  <motion.div 
                    className={`absolute -inset-2 bg-gradient-to-br ${feature.gradient} rounded-3xl blur opacity-0 group-hover:opacity-50`}
                    transition={{ duration: 0.3 }}
                  />

                  {/* Icon */}
                  <motion.svg 
                    className="w-12 h-12 text-white relative z-10" 
                    fill="none" 
                    stroke="currentColor" 
                    viewBox="0 0 24 24"
                    whileHover={{ scale: 1.1 }}
                    transition={{ duration: 0.3 }}
                  >
                    {feature.icon}
                    {feature.iconSecond}
                  </motion.svg>

                  {/* Rotating Border */}
                  <motion.div 
                    className="absolute -inset-1 border-2 border-white/20 rounded-3xl"
                    animate={{ rotate: 360 }}
                    transition={{ duration: 8, repeat: Infinity, ease: "linear" }}
                  />

                  {/* Pulse Effect */}
                  <motion.div 
                    className={`absolute inset-0 bg-gradient-to-br ${feature.gradient} rounded-3xl opacity-0 group-hover:opacity-30`}
                    animate={{
                      scale: [1, 1.2, 1],
                      opacity: [0, 0.3, 0]
                    }}
                    transition={{ duration: 2, repeat: Infinity }}
                  />
                </motion.div>

                {/* Enhanced Text Content */}
                <motion.div
                  initial={{ opacity: 0, y: 20 }}
                  whileInView={{ opacity: 1, y: 0 }}
                  viewport={{ once: true }}
                  transition={{ duration: 0.6, delay: 0.1 + index * 0.1 }}
                >
                  <motion.h3 
                    className="text-xl font-bold text-white mb-4 group-hover:text-amber-400 transition-colors duration-300"
                    whileHover={{ scale: 1.05 }}
                    transition={{ type: "spring", stiffness: 300 }}
                  >
                    {feature.title}
                  </motion.h3>
                  
                  <motion.p 
                    className="text-white/70 leading-relaxed group-hover:text-white/90 transition-colors duration-300"
                    initial={{ opacity: 0.7 }}
                    whileHover={{ opacity: 1 }}
                  >
                    {feature.description}
                  </motion.p>
                </motion.div>

                {/* Hover Line Effect */}
                <motion.div 
                  className="h-1 bg-gradient-to-r from-amber-400 to-amber-600 rounded-full mt-4 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"
                />
              </motion.div>
            ))}
          </motion.div>
        </div>
      </motion.section>

      {/* Portfolio Preview Section */}
      <section id="portfolio" className="mx-auto max-w-7xl px-6 py-24">
        <div className="text-center mb-16">
          <p className="text-amber-400 uppercase tracking-wide text-sm font-semibold mb-4">Our Work</p>
          <h2 className="text-4xl md:text-6xl font-bold text-white mb-6">Our Photo Gallery</h2>
          <p className="text-white/70 max-w-2xl mx-auto text-lg">
            Explore our diverse photography portfolio, showcasing our expertise and creativity in capturing unforgettable moments.
          </p>
        </div>

        <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
          {/* Wedding Gallery */}
          <div className="relative group h-96 rounded-2xl overflow-hidden">
            <div className="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent z-10"></div>
            <Image
              src="https://images.unsplash.com/photo-1606216794074-735e91aa2c92?q=80&w=800&auto=format&fit=crop"
              alt="Wedding Photography"
              width={600}
              height={400}
              className="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
            />
            <div className="absolute bottom-8 left-8 z-20">
              <p className="text-white/70 text-sm mb-2">Weddings</p>
              <h3 className="text-2xl font-bold text-white">Elegant Wedding Album</h3>
            </div>
          </div>

          {/* Portrait Gallery */}
          <div className="relative group h-96 rounded-2xl overflow-hidden">
            <div className="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent z-10"></div>
            <Image
              src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=800&auto=format&fit=crop"
              alt="Professional Headshots"
              width={600}
              height={400}
              className="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
            />
            <div className="absolute bottom-8 left-8 z-20">
              <p className="text-white/70 text-sm mb-2">Headshots</p>
              <h3 className="text-2xl font-bold text-white">Professional Headshots</h3>
            </div>
          </div>

          {/* Event Gallery */}
          <div className="relative group h-96 rounded-2xl overflow-hidden">
            <div className="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent z-10"></div>
            <Image
              src="https://images.unsplash.com/photo-1511285560929-80b456fea0bc?q=80&w=800&auto=format&fit=crop"
              alt="Graduation Photography"
              width={600}
              height={400}
              className="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
            />
            <div className="absolute bottom-8 left-8 z-20">
              <p className="text-white/70 text-sm mb-2">Graduation</p>
              <h3 className="text-2xl font-bold text-white">Stunning Graduation Shots</h3>
            </div>
          </div>

          {/* Product Gallery */}
          <div className="relative group h-96 rounded-2xl overflow-hidden">
            <div className="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent z-10"></div>
            <Image
              src="https://images.unsplash.com/photo-1560472354-b33ff0c44a43?q=80&w=800&auto=format&fit=crop"
              alt="Product Photography"
              width={600}
              height={400}
              className="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
            />
            <div className="absolute bottom-8 left-8 z-20">
              <p className="text-white/70 text-sm mb-2">Products</p>
              <h3 className="text-2xl font-bold text-white">Vibrant Product Display</h3>
            </div>
          </div>
        </div>

        <div className="text-center mt-12">
          <Button asChild size="lg" className="bg-gradient-to-r from-amber-500 to-orange-600 hover:from-amber-600 hover:to-orange-700">
            <Link href="/gallery">
              View Full Gallery
            </Link>
          </Button>
        </div>
      </section>

      {/* Call to Action Section */}
      <section className="mx-auto max-w-7xl px-6 py-24">
        <div className="bg-gradient-to-r from-blue-600/20 to-purple-600/20 backdrop-blur-sm rounded-3xl p-12 text-center border border-white/10">
          <h2 className="text-3xl md:text-5xl font-bold text-white mb-6">
            Ready to Create Something Amazing?
          </h2>
          <p className="text-white/70 text-lg mb-8 max-w-2xl mx-auto">
            Let's bring your vision to life with professional photography that tells your unique story. Contact us today to discuss your project.
          </p>
          <div className="flex flex-col sm:flex-row gap-4 justify-center">
            <Button asChild size="lg" className="bg-gradient-to-r from-amber-500 to-orange-600 hover:from-amber-600 hover:to-orange-700 px-8">
              <Link href="/contact">
                Get Started Today
              </Link>
            </Button>
            <Button asChild size="lg" variant="outline" className="border-white/30 text-white hover:bg-white/10">
              <Link href="/services">
                View Our Services
              </Link>
            </Button>
          </div>
        </div>
      </section>
    </main>
  );
}

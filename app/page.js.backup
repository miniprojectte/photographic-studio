              >
                <div className="w-28 h-16 bg-white/5 backdrop-blur-sm rounded-2xl flex items-center justify-center border border-white/10 group-hover:border-amber-500/50 group-hover:bg-white/10 transition-all duration-300">
                  <span className="text-white/70 group-hover:text-amber-400 text-xs font-bold tracking-wider transition-all duration-300">
                    {brand}
